# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=true
API_KEY=super-secret-key-12345

# Database Settings
# Note: For PGAdmin / PostgreSQL, replace with your active connection credentials.
# Local development default uses PostgreSQL local default
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/english_to_hausa

# Cloud Storage (Optional - falls back to local static routing if blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paths
STORAGE_DIR=C:\Backend\english_to_hausa\downloads
MODEL_CACHE_DIR=C:\Backend\english_to_hausa\models_cache

# Processing Limits
MAX_VIDEO_DURATION_SECONDS=7200
MAX_TEXT_LENGTH=10000
MAX_TTS_TEXT_LENGTH=5000
